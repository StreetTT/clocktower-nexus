{
  "name": "clocktower-nexus",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "clocktower-nexus",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": "^22.0.0",
        "npm": "^10.0.0"
      }
    },
    "apps/game-hub": {
      "name": "@clocktower-nexus/game-hub",
      "version": "0.0.0"
    },
    "apps/public-square": {
      "name": "@clocktower-nexus/public-square",
      "version": "0.0.0"
    },
    "apps/storyteller-console": {
      "name": "@clocktower-nexus/storyteller-console",
      "version": "0.0.0"
    },
    "node_modules/@clocktower-nexus/domain": {
      "resolved": "packages/domain",
      "link": true
    },
    "node_modules/@clocktower-nexus/game-hub": {
      "resolved": "apps/game-hub",
      "link": true
    },
    "node_modules/@clocktower-nexus/protocol": {
      "resolved": "packages/protocol",
      "link": true
    },
    "node_modules/@clocktower-nexus/public-square": {
      "resolved": "apps/public-square",
      "link": true
    },
    "node_modules/@clocktower-nexus/script-compatibility": {
      "resolved": "packages/script-compatibility",
      "link": true
    },
    "node_modules/@clocktower-nexus/script-import": {
      "resolved": "packages/script-import",
      "link": true
    },
    "node_modules/@clocktower-nexus/script-normalization": {
      "resolved": "packages/script-normalization",
      "link": true
    },
    "node_modules/@clocktower-nexus/storyteller-console": {
      "resolved": "apps/storyteller-console",
      "link": true
    },
    "packages/domain": {
      "name": "@clocktower-nexus/domain",
      "version": "0.0.0"
    },
    "packages/protocol": {
      "name": "@clocktower-nexus/protocol",
      "version": "0.0.0"
    },
    "packages/script-compatibility": {
      "name": "@clocktower-nexus/script-compatibility",
      "version": "0.0.0"
    },
    "packages/script-import": {
      "name": "@clocktower-nexus/script-import",
      "version": "0.0.0"
    },
    "packages/script-normalization": {
      "name": "@clocktower-nexus/script-normalization",
      "version": "0.0.0"
    }
  }
}
